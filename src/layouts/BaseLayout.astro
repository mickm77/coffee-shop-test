---
// simple layout wrapping pages
import '../styles.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><slot name="title" /></title>
    <!-- Google Fonts for headings and body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <script is:inline>
      if (
        localStorage.getItem('color-theme') === 'dark' ||
        (!('color-theme' in localStorage) &&
          window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="font-sans antialiased bg-coffee-50 text-secondary dark:bg-coffee-950 dark:text-coffee-50 transition-colors duration-300 relative selection:bg-primary/30 selection:text-primary-dark dark:selection:text-primary-light">
    <!-- Subtle grain overlay for texture -->
    <div class="fixed inset-0 pointer-events-none opacity-[0.03] dark:opacity-[0.05] bg-noise mix-blend-overlay z-50"></div>
    <slot />
  </body>
</html>
