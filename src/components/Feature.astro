---
export interface Props {
  title: string;
  description: string;
  icon?: string;
  class?: string;
}

const { title, description, icon, class: className = '' } = Astro.props;
---

<div class={`flex flex-col items-start ${className}`}>
  {icon && (
    <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary/10 text-primary mb-4 shrink-0">
      <span class="text-2xl" set:html={icon} />
    </div>
  )}
  <h3 class="text-xl font-bold mb-2 text-gray-900">{title}</h3>
  <p class="text-gray-600 leading-relaxed">
    {description}
  </p>
</div>
