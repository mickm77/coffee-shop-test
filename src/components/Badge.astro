---
export interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'gray' | 'success' | 'error';
  class?: string;
}

const { variant = 'primary', class: className = '' } = Astro.props;

const variants = {
  primary: 'bg-primary/10 text-primary border-primary/20',
  secondary: 'bg-secondary/10 text-secondary border-secondary/20',
  accent: 'bg-accent/10 text-accent border-accent/20',
  gray: 'bg-gray-100 text-gray-800 border-gray-200',
  success: 'bg-green-100 text-green-800 border-green-200',
  error: 'bg-red-100 text-red-800 border-red-200',
};

const classes = `inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border ${variants[variant]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
