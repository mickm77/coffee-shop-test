---
export interface Props {
  links?: { title: string; href: string }[];
}

import Button from './Button.astro';
import ThemeToggle from './ThemeToggle.astro';

const { links = [
  { title: "Home", href: "/" },
  { title: "Features", href: "#features" },
  { title: "Testimonials", href: "#testimonials" },
  { title: "Pricing", href: "#pricing" }
] } = Astro.props;
---

<nav class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800 sticky top-0 z-50 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0 flex items-center font-extrabold text-2xl tracking-tighter text-primary dark:text-white">
        <a href="/" class="flex items-center gap-2">
          {Astro.slots.has('logo') ? <slot name="logo"/> : <span><span class="text-secondary dark:text-blue-400">Lego</span>Kit</span>}
        </a>
      </div>
      
      <div class="hidden md:flex space-x-8 items-center">
        {links.map((link) => (
          <a href={link.href} class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-white font-medium transition-colors">
            {link.title}
          </a>
        ))}
        <ThemeToggle />
        <Button variant="primary" size="sm" class="ml-4 rounded-full font-bold px-6">Get Started</Button>
      </div>

      <div class="md:hidden flex items-center gap-2">
        <ThemeToggle />
        <button id="mobile-menu-button" type="button" class="text-gray-500 dark:text-gray-400 hover:text-primary dark:hover:text-white focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col space-y-2 pt-2">
        {links.map((link) => (
          <a href={link.href} class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-white font-medium transition-colors px-3 py-2 rounded-md hover:bg-gray-50 dark:hover:bg-gray-800">
            {link.title}
          </a>
        ))}
        <div class="px-3 pt-2">
          <Button variant="primary" size="sm" class="w-full rounded-full font-bold">Get Started</Button>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });

    // Close menu when a link is clicked
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>
