---
export interface Props {
  links?: { title: string; href: string }[];
}

import Button from "./Button.astro";
import ThemeToggle from "./ThemeToggle.astro";

const {
  links = [
    { title: "Home", href: "/" },
    { title: "Our Story", href: "#about" },
    { title: "Menu", href: "#menu" },
    { title: "Reviews", href: "#testimonials" },
    { title: "FAQ", href: "#faq" },
  ],
} = Astro.props;
---

<nav
  class="bg-coffee-50/80 dark:bg-coffee-950/80 backdrop-blur-md border-b border-coffee-200/50 dark:border-coffee-800/50 sticky top-0 z-50 transition-colors duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24">
      <div
        class="flex-shrink-0 flex items-center font-serif font-bold text-3xl tracking-tight text-secondary dark:text-white"
      >
        <a href="/" class="flex items-center gap-2 group">
          {
            Astro.slots.has("logo") ? (
              <slot name="logo" />
            ) : (
              <span class="group-hover:text-primary transition-colors">
                Mocha <span class="text-primary font-light italic">Stop</span>
              </span>
            )
          }
        </a>
      </div>

      <div class="hidden md:flex space-x-10 items-center">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium tracking-widest uppercase text-secondary-light dark:text-coffee-200 hover:text-primary dark:hover:text-primary transition-colors relative group"
            >
              {link.title}
              <span class="absolute -bottom-2 left-0 w-0 h-[2px] bg-primary transition-all duration-300 group-hover:w-full" />
            </a>
          ))
        }
        <div
          class="flex items-center gap-6 pl-6 border-l border-coffee-200/50 dark:border-coffee-800/50"
        >
          <ThemeToggle />
          <Button
            variant="secondary"
            size="sm"
            class="rounded-none tracking-widest px-8">Order Now</Button
          >
        </div>
      </div>

      <div class="md:hidden flex items-center gap-4">
        <ThemeToggle />
        <button
          id="mobile-menu-button"
          type="button"
          class="text-secondary dark:text-coffee-200 hover:text-primary focus:outline-none"
        >
          <svg
            class="h-8 w-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-6">
      <div
        class="flex flex-col space-y-4 pt-4 border-t border-coffee-200/50 dark:border-coffee-800/50"
      >
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-secondary-light dark:text-coffee-200 hover:text-primary dark:hover:text-primary font-medium tracking-widest uppercase transition-colors px-4 py-3 bg-white/50 dark:bg-coffee-900/50 rounded-lg"
            >
              {link.title}
            </a>
          ))
        }
        <div class="px-4 pt-4">
          <Button
            variant="secondary"
            size="lg"
            class="w-full rounded-none tracking-widest">Order Now</Button
          >
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  if (btn && menu) {
    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });

    // Close menu when a link is clicked
    const links = menu.querySelectorAll("a");
    links.forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
      });
    });
  }
</script>
