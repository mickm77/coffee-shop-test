---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<details class="group border-b border-gray-200 dark:border-gray-800 last:border-0 hover:bg-gray-50/50 dark:hover:bg-gray-800/50 transition-colors">
  <summary class="flex justify-between items-center font-medium cursor-pointer list-none py-5 px-4 text-gray-900 dark:text-gray-100 group-open:text-primary">
    <span>{title}</span>
    <span class="transition-transform group-open:rotate-180">
      <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
    </span>
  </summary>
  <div class="text-gray-600 dark:text-gray-400 px-4 pb-5 leading-relaxed">
    <slot />
  </div>
</details>
