---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<details class="group border-b border-coffee-200/50 dark:border-coffee-800/50 last:border-0 hover:bg-coffee-100/30 dark:hover:bg-coffee-900/30 transition-colors">
  <summary class="flex justify-between items-center cursor-pointer list-none py-6 px-6 font-serif text-lg text-secondary dark:text-coffee-50 group-open:text-primary transition-colors">
    <span>{title}</span>
    <span class="transition-transform duration-300 group-open:rotate-180 text-primary">
      <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
    </span>
  </summary>
  <div class="text-secondary-light dark:text-coffee-200 px-6 pb-6 leading-loose font-light">
    <slot />
  </div>
</details>
