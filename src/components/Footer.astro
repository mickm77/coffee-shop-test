---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 border-t border-gray-800 pt-16 pb-8 text-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-8 mb-12">
      <div class="col-span-1 md:col-span-1">
        <span class="text-2xl font-extrabold tracking-tighter text-white">Lego<span class="text-accent">Kit</span></span>
        <p class="mt-4 text-gray-400 text-sm leading-relaxed">
          The perfect starting point for any small business website. Fast, responsive, and beautiful UI components out of the box.
        </p>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-4">Product</h3>
        <ul role="list" class="space-y-3">
          <li><a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">Features</a></li>
          <li><a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">Pricing</a></li>
          <li><a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">Testimonials</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-4">Company</h3>
        <ul role="list" class="space-y-3">
          <li><a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">About</a></li>
          <li><a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">Blog</a></li>
          <li><a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-4">Legal</h3>
        <ul role="list" class="space-y-3">
          <li><a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">Privacy</a></li>
          <li><a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">Terms</a></li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0 text-sm text-gray-400">
      <p>&copy; {currentYear} Small Business OS. All rights reserved.</p>
      <div class="flex space-x-6">
        <a href="#" class="hover:text-white transition-colors">
          <span class="sr-only">Twitter</span>
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
