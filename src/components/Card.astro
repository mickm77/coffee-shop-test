---
export interface Props {
  title?: string;
  class?: string;
}

const { title, class: className = '' } = Astro.props;
---

<div class={`bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-100 dark:border-gray-800 overflow-hidden hover:shadow-md transition-shadow duration-300 ${className}`}>
  {Astro.slots.has('image') && (
    <div class="w-full relative">
      <slot name="image" />
    </div>
  )}
  <div class="p-6">
    {title && <h3 class="text-xl font-bold mb-2 text-gray-900 dark:text-white">{title}</h3>}
    <div class="text-gray-600 dark:text-gray-400">
      <slot />
    </div>
  </div>
  {Astro.slots.has('footer') && (
    <div class="px-6 py-4 bg-gray-50 dark:bg-gray-950/50 border-t border-gray-100 dark:border-gray-800">
      <slot name="footer" />
    </div>
  )}
</div>
