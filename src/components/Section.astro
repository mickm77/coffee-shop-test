---
export interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
  bg?: 'white' | 'gray' | 'primary' | 'dark';
}

const { title, subtitle, class: className = '', bg = 'white' } = Astro.props;

const bgColors = {
  white: 'bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100',
  gray: 'bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 border-y border-gray-100 dark:border-gray-800',
  primary: 'bg-primary/5 dark:bg-primary/10 text-gray-900 dark:text-gray-100 border-y border-primary/10 dark:border-primary/20',
  dark: 'bg-gray-900 dark:bg-black text-white dark:text-gray-100',
};
---

<section class={`py-20 md:py-28 ${bgColors[bg]} ${className}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {(title || subtitle) && (
      <div class="text-center max-w-3xl mx-auto mb-16">
        {subtitle && <p class={`text-sm font-bold tracking-wide uppercase mb-3 ${bg === 'dark' ? 'text-accent' : 'text-primary'}`}>{subtitle}</p>}
        {title && <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-4">{title}</h2>}
      </div>
    )}
    <slot />
  </div>
</section>
