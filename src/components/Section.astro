---
export interface Props {
  title?: string;
  subtitle?: string;
  class?: string;
  bg?: 'white' | 'gray' | 'primary' | 'dark';
}

const { title, subtitle, class: className = '', bg = 'white' } = Astro.props;

const bgColors = {
  white: 'bg-coffee-50 dark:bg-coffee-950 text-secondary dark:text-coffee-50 relative',
  gray: 'bg-coffee-100/50 dark:bg-coffee-900/50 text-secondary dark:text-coffee-50 border-y border-coffee-200/50 dark:border-coffee-800/50 backdrop-blur-sm relative z-10',
  primary: 'bg-primary/5 dark:bg-primary/10 text-secondary dark:text-coffee-50 border-y border-primary/10 dark:border-primary/20 backdrop-blur-md relative z-10',
  dark: 'bg-coffee-900 dark:bg-black text-coffee-50 relative z-10',
};
---

<section class={`py-24 md:py-32 overflow-hidden ${bgColors[bg]} ${className}`}>
  <!-- Decorative background elements -->
  {bg === 'gray' && <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 rounded-full bg-primary/5 blur-3xl pointer-events-none"></div>}
  {bg === 'white' && <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-96 h-96 rounded-full bg-primary/5 blur-3xl pointer-events-none"></div>}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    {(title || subtitle) && (
      <div class="text-center max-w-3xl mx-auto mb-20 animate-fade-in-up">
        {subtitle && (
          <div class="inline-flex items-center gap-4 mb-4">
            <span class="w-8 h-[1px] bg-primary"></span>
            <span class={`text-sm font-semibold tracking-[0.2em] uppercase ${bg === 'dark' ? 'text-primary-light' : 'text-primary'}`}>{subtitle}</span>
            <span class="w-8 h-[1px] bg-primary"></span>
          </div>
        )}
        {title && <h2 class="text-4xl md:text-6xl font-serif font-light tracking-tight mb-6">{title}</h2>}
      </div>
    )}
    <slot />
  </div>
</section>
