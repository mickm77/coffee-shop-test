---
export interface Props {
  title: string;
  price: string;
  features: string[];
  isPopular?: boolean;
  buttonText?: string;
  buttonVariant?: 'primary' | 'outline';
}

const { 
  title, 
  price, 
  features, 
  isPopular = false, 
  buttonText = 'Get Started',
  buttonVariant = isPopular ? 'primary' : 'outline'
} = Astro.props;

import Button from './Button.astro';
---

<div class={`relative flex flex-col p-8 rounded-2xl bg-white dark:bg-gray-900 border ${isPopular ? 'border-primary ring-1 ring-primary shadow-xl' : 'border-gray-200 dark:border-gray-800 shadow-sm'} hover:shadow-lg transition-all duration-300`}>
  {isPopular && (
    <div class="absolute -top-4 left-0 right-0 mx-auto w-fit px-4 py-1 rounded-full bg-primary text-white text-sm font-semibold tracking-wide uppercase">
      Most Popular
    </div>
  )}
  
  <div class="mb-5">
    <h3 class="text-2xl font-bold text-gray-900 dark:text-white">{title}</h3>
    <div class="mt-4 flex items-baseline text-gray-900 dark:text-white">
      <span class="text-5xl font-extrabold tracking-tight">{price}</span>
      {price !== 'Custom' && <span class="ml-1 text-xl font-medium text-gray-500 dark:text-gray-400">/mo</span>}
    </div>
  </div>

  <ul role="list" class="flex-1 space-y-4 mb-8">
    {features.map((feature) => (
      <li class="flex items-start">
        <svg class="h-6 w-6 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        <span class="ml-3 text-gray-600 dark:text-gray-400">{feature}</span>
      </li>
    ))}
  </ul>

  <Button variant={buttonVariant} class="w-full w-full">{buttonText}</Button>
</div>
