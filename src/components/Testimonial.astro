---
export interface Props {
  quote: string;
  author: string;
  role?: string;
  avatarUrl?: string;
}

const { quote, author, role, avatarUrl } = Astro.props;
---

<div class="bg-white/80 dark:bg-coffee-950/60 backdrop-blur-md rounded-none p-10 border border-coffee-200/50 dark:border-coffee-800/50 relative shadow-sm hover:shadow-xl transition-all duration-500">
  <div class="absolute -top-6 -left-4 text-7xl font-serif text-primary/30 dark:text-primary/10 select-none">"</div>
  <p class="text-xl font-serif italic text-secondary-light dark:text-coffee-200 leading-loose relative z-10 pt-4 mb-8">
    {quote}
  </p>
  <div class="flex items-center gap-5">
    {avatarUrl ? (
      <img src={avatarUrl} alt={author} class="w-14 h-14 object-cover border-2 border-primary/20" />
    ) : (
      <div class="w-14 h-14 bg-coffee-100 dark:bg-coffee-900 flex items-center justify-center text-primary font-serif italic text-2xl border border-primary/20">
        {author.charAt(0)}
      </div>
    )}
    <div>
      <h4 class="font-bold font-serif tracking-wide text-secondary dark:text-white uppercase text-sm">{author}</h4>
      {role && <p class="text-sm font-light text-primary mt-1">{role}</p>}
    </div>
  </div>
</div>
