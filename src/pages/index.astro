---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Feature from '../components/Feature.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import Testimonial from '../components/Testimonial.astro';
import PricingPlan from '../components/PricingPlan.astro';
import Accordion from '../components/Accordion.astro';
import Footer from '../components/Footer.astro';
import MenuCard from '../components/MenuCard.astro';
import { fetchSheet } from '../lib/googleSheets';

// build-time data fetch (keeping the original feature)
const sheetId = import.meta.env.SHEET_ID || '1LaybHog8a56T2RP6XgJWeYvCugvOOfHIDfRenaPb3CM';
const menuRange = 'Sheet1!A1:E10';
let menuItems = [];

try {
  const rawData = await fetchSheet(sheetId, menuRange);
  // skip the header row, if it exists, assuming first row is headers
  const data = rawData[0] && rawData[0][0] && rawData[0][0].toLowerCase().includes('title') || rawData[0][0].toLowerCase().includes('id') ? rawData.slice(1) : rawData;
  menuItems = data.map(([title, description, price]) => ({ title, description, price }));
} catch (e) {
  // Graceful fallback if no google api setup
  console.warn("Could not fetch from Google Sheets", e);
  menuItems = [
    { title: "Mocha Supreme", description: "Our signature espresso blend with rich dark chocolate and steamed milk.", price: "$5.50" },
    { title: "Caramel Latte", description: "Smooth espresso with buttery caramel syrup and velvety foam.", price: "$4.75" },
    { title: "Cold Brew Double", description: "Slow-steeped for 18 hours, served over ice for a bold finish.", price: "$5.00" }
  ];
}
---

<BaseLayout>
  <slot name="title">Mocha Stop - The Perfect Brew</slot>

  <Navbar />

  <Hero
    headline="Coffee that stops time."
    subheadline="Experience artisan roasts and premium blends at Mocha Stop. Your neighborhood's favorite morning destination, now serving from our heart to your cup."
    ctaText="View Our Menu"
    ctaUrl="#menu"
    secondaryCtaText="Visit Us"
    secondaryCtaUrl="#about"
    backgroundImage="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?q=80&w=2070&auto=format&fit=crop"
  />

  <Section id="about" title="Crafting the Perfect Cup" subtitle="Our Story" bg="white">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mt-12">
      <Feature 
        title="Artisan Roasting" 
        description="We source only the finest single-origin beans, roasted locally in small batches for maximum flavor."
        icon="☕"
      />
      <Feature 
        title="Cozy Atmosphere" 
        description="A warm, inviting space with free Wi-Fi and comfortable seating. Perfect for work or catching up."
        icon="🏘️"
      />
      <Feature 
        title="Ethically Sourced" 
        description="Supporting sustainable farming practices and ensuring fair wages for our coffee growers."
        icon="🌍"
      />
    </div>
  </Section>

  <Section id="menu" title="Our Signature Blends" subtitle="Menu Highlights" bg="gray">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {menuItems.map(item => (
        <MenuCard
          title={item.title}
          description={item.description}
          price={item.price}
        />
      ))}
    </div>
  </Section>

  <Section id="testimonials" title="What Our Regulars Say" subtitle="Testimonials" bg="gray">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <Testimonial 
        quote="The Mocha Supreme is easily the best coffee I've ever had. Truly life-changing!"
        author="James P."
        role="Coffee Enthusiast"
      />
      <Testimonial 
        quote="My favorite place to work. The atmosphere is quiet, and the staff is incredibly friendly."
        author="Linda M."
        role="Remote Freelancer"
      />
    </div>
  </Section>

  <Section id="faq" title="Common Questions" subtitle="FAQ" bg="white">
    <div class="max-w-3xl mx-auto bg-white/60 dark:bg-coffee-950/60 backdrop-blur-md rounded-none shadow-sm border border-coffee-200/50 dark:border-coffee-800/50 overflow-hidden">
      <Accordion title="Do you have plant-based milks?">
        Yes! We offer Oat, Almond, and Soy milk for all our espresso-based drinks.
      </Accordion>
      <Accordion title="Is there outdoor seating?">
        Absolutely. We have a cozy patio area with plenty of shade.
      </Accordion>
      <Accordion title="Can I host a small meeting at Mocha Stop?">
        We love hosting meetings! Give us a call in advance if you're bringing a group of 6 or more.
      </Accordion>
    </div>
  </Section>

  <Footer />
</BaseLayout>
